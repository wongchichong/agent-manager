{
  "name": "agent-manager",
  "version": "1.0.0",
  "description": "TUI agent orchestrator — spawn, pipe, and manage CLI agents",
  "type": "module",
  "bin": {
    "agentman": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.tsx",
    "build": "vite build && chmod +x dist/index.js",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@xterm/headless": "^6.0.0",
    "ink": "^5.0.1",
    "node-pty": "^1.1.0",
    "react": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.12"
  }
}
